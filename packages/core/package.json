  "author": "anonymous.rs <jeff.cofos@gmail.com>",
  "description": "Liverse Live Commerce Core SDK",
  "keywords": [],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts --format cjs,esm --clean --dts --minify"
  },
  "dependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
